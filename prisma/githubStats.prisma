model GithubStats {
  id                String   @id @default(cuid())

  githubUsername    String   @unique

  followers         Int      @default(0)
  following         Int      @default(0)

  publicRepos       Int      @default(0)

  totalStars        Int      @default(0)

  lastSyncedAt      DateTime?

  updatedAt         DateTime @updatedAt
}