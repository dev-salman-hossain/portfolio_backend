model Portfolio {
  id String @id @default(cuid())

  heroTitle       String
  heroSubtitle    String?
  heroDescription String?

  profileImage String?
  coverImage   String?

  resumeUrl String?

  about String

  email    String?
  phone    String?
  location String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
